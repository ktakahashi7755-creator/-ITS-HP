# ===== ITS合同会社 (its-tokyo.com) — Xserver / Apache =====

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Force HTTPS ---
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # --- (任意) www を非wwwへ統一：canonical(https://its-tokyo.com/)に合わせる場合は有効化 ---
  # RewriteCond %{HTTP_HOST} ^www\.its-tokyo\.com [NC]
  # RewriteRule ^(.*)$ https://its-tokyo.com/$1 [R=301,L]

  # --- 旧URL / よくある別表記を正しいページへ 301 リダイレクト（検索結果のリンク切れ対策） ---
  RewriteRule ^(about|aboutus|about-us|about\.html|company\.html)/?$        /#about       [R=301,L,NC]
  RewriteRule ^(company|company-profile|profile|outline)/?$                  /#company     [R=301,L,NC]
  RewriteRule ^(philosophy|mission|vision)\.?(html)?/?$                      /#philosophy  [R=301,L,NC]
  RewriteRule ^(service|services\.php|service\.html)/?$                      /services.html [R=301,L,NC]
  RewriteRule ^(works|work|portfolio)\.?(html)?/?$                           /#works       [R=301,L,NC]
  RewriteRule ^(contact|contactus|contact-us|contact\.html|inquiry)/?$       /#contact     [R=301,L,NC]
  RewriteRule ^(recruit|career|careers)\.?(html)?/?$                         /#contact     [R=301,L,NC]
  RewriteRule ^(familink|product|products)\.?(html)?/?$                      /familink.html [R=301,L,NC]
  RewriteRule ^index\.(php|htm)$                                             /            [R=301,L,NC]
</IfModule>

# --- 404: 見つからないURLは案内ページへ ---
ErrorDocument 404 /404.html

# --- Default document ---
DirectoryIndex index.html

# --- Gzip compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# --- Browser caching ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType text/css               "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg             "access plus 30 days"
  ExpiresByType image/png              "access plus 30 days"
  ExpiresByType image/webp             "access plus 30 days"
  ExpiresByType image/svg+xml          "access plus 30 days"
  ExpiresByType font/woff2             "access plus 365 days"
</IfModule>

# --- Security headers (light) ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
